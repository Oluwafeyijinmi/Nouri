{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with delivery and contact preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "A food product on the storefront managed by admins.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "tags": { "type": "array" },
        "isPopular": { "type": "boolean" },
        "sizes": { "type": "array" },
        "extras": { "type": "array" }
      },
      "required": ["id", "name", "description", "category", "price", "image", "tags"]
    },
    "Order": {
      "title": "Food Order",
      "description": "Record of a placed order containing meals and status.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["received", "preparing", "out_for_delivery", "delivered"] },
        "createdAt": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "deliveryPhone": { "type": "string" },
        "deliveryName": { "type": "string" }
      },
      "required": ["orderId", "userId", "items", "total", "status", "createdAt"]
    },
    "FCMToken": {
      "title": "FCM Device Token",
      "description": "Token mapping for Firebase Cloud Messaging push registrations",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["token", "userId"]
    },
    "PushNotification": {
      "title": "Push Notification",
      "description": "Sent push notification message for order updates and promo campaigns",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["order_update", "promo"] },
        "sentAt": { "type": "string" },
        "read": { "type": "boolean" },
        "orderId": { "type": "string" }
      },
      "required": ["id", "userId", "title", "body", "type", "sentAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile details"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Placed food orders"
    },
    "menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Storefront products and prices"
    },
    "fcm_tokens/{tokenId}": {
      "schema": "FCMToken",
      "description": "Active push notification registration tokens"
    },
    "push_notifications/{notificationId}": {
      "schema": "PushNotification",
      "description": "Sent in-app and push notifications history"
    }
  }
}

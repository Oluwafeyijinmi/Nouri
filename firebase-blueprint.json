{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with delivery and contact preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "A food product on the storefront managed by admins.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "tags": { "type": "array" },
        "isPopular": { "type": "boolean" },
        "sizes": { "type": "array" },
        "extras": { "type": "array" }
      },
      "required": ["id", "name", "description", "category", "price", "image", "tags"]
    },
    "Order": {
      "title": "Food Order",
      "description": "Record of a placed order containing meals and status.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["received", "preparing", "out_for_delivery", "delivered"] },
        "createdAt": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "deliveryPhone": { "type": "string" },
        "deliveryName": { "type": "string" }
      },
      "required": ["orderId", "userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile details"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Placed food orders"
    },
    "menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Storefront products and prices"
    }
  }
}
